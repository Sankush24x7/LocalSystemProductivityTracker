<Window x:Class="ProductivityTracker.App.QuickAddTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quick Add Task"
        Height="360"
        Width="460"
        Background="#0F1622"
        Foreground="#EAF0FF"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Quick Add Task" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,10" />

        <TextBox Grid.Row="1" x:Name="TitleTextBox" ToolTip="Task title" Margin="0,0,0,8" />
        <TextBox Grid.Row="2" x:Name="DescriptionTextBox" Height="70" TextWrapping="Wrap" AcceptsReturn="True" ToolTip="Description" Margin="0,0,0,8" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
            <ComboBox x:Name="PriorityComboBox" Width="130" IsEditable="True" IsReadOnly="True" />
            <ComboBox x:Name="StatusComboBox" Width="130" Margin="8,0,0,0" IsEditable="True" IsReadOnly="True" />
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,8">
            <DatePicker x:Name="DueDatePicker" Width="200" />
            <TextBox x:Name="DueTimeTextBox" Width="80" Margin="8,0,0,0" Text="18:00" ToolTip="HH:mm" />
            <CheckBox x:Name="NoDueCheckBox" Content="No Due" Margin="12,4,0,0" Checked="NoDueCheckBox_Changed" Unchecked="NoDueCheckBox_Changed" />
        </StackPanel>

        <TextBlock Grid.Row="5" x:Name="StatusText" Foreground="#9FC2E9" Margin="0,4,0,0" />

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Width="100" Margin="0,0,8,0" Content="Add" Click="Add_Click" />
            <Button Width="100" Content="Cancel" Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>
