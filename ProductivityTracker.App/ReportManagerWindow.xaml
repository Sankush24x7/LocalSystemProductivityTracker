<Window x:Class="ProductivityTracker.App.ReportManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Report Manager"
        Height="520"
        Width="980"
        Background="#0F1622"
        Foreground="#E8F0FF"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#253042" />
            <Setter Property="Foreground" Value="#EAF0FF" />
            <Setter Property="BorderBrush" Value="#3A4C65" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="4" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#101A2A" />
            <Setter Property="Foreground" Value="#EAF0FF" />
            <Setter Property="BorderBrush" Value="#2F435E" />
            <Setter Property="RowBackground" Value="#0F1A2A" />
            <Setter Property="AlternatingRowBackground" Value="#122036" />
            <Setter Property="HorizontalGridLinesBrush" Value="#2A3F5C" />
            <Setter Property="VerticalGridLinesBrush" Value="#2A3F5C" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="All" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A2940" />
            <Setter Property="Foreground" Value="#F2F7FF" />
            <Setter Property="BorderBrush" Value="#2F435E" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="#EAF0FF" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2E6695" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="#EAF0FF" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#2A3F5C" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="6,4" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2E6695" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,8">
            <TextBlock FontSize="24" FontWeight="SemiBold" Text="Day-wise Report Files" DockPanel.Dock="Left" />
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="Refresh" Click="Refresh_Click" />
                <Button Content="Open JSON" Click="OpenJson_Click" />
                <Button Content="Open HTML" Click="OpenHtml_Click" />
                <Button Content="Delete Selected Day" Click="DeleteSelected_Click" Background="#7A2D34" BorderBrush="#AD4A55" />
            </StackPanel>
        </DockPanel>

        <DataGrid Grid.Row="1"
                  x:Name="ReportGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Date" Binding="{Binding DateLabel}" Width="140" />
                <DataGridTextColumn Header="JSON File" Binding="{Binding JsonName}" Width="260" />
                <DataGridTextColumn Header="HTML File" Binding="{Binding HtmlName}" Width="260" />
                <DataGridTextColumn Header="JSON Exists" Binding="{Binding JsonExists}" Width="120" />
                <DataGridTextColumn Header="HTML Exists" Binding="{Binding HtmlExists}" Width="120" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="2" x:Name="StatusText" Margin="2,10,2,0" Foreground="#9AB4D5" Text="Select a day and choose an action." />
    </Grid>
</Window>
