<Window x:Class="ProductivityTracker.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Height="820"
        Width="760"
        Background="#0F1622"
        Foreground="#E8F0FF"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8F0FF" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E8F0FF" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#141F30" />
            <Setter Property="Foreground" Value="#F2F7FF" />
            <Setter Property="BorderBrush" Value="#355076" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontSize" Value="15" />
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#141F30" />
            <Setter Property="Foreground" Value="#F2F7FF" />
            <Setter Property="BorderBrush" Value="#355076" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontSize" Value="15" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#EAF0FF" />
            <Setter Property="Foreground" Value="#0B1220" />
            <Setter Property="BorderBrush" Value="#355076" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MaxDropDownHeight" Value="220" />
            <Setter Property="IsEditable" Value="True" />
            <Setter Property="IsReadOnly" Value="True" />
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#0C1321" />
            <Setter Property="Background" Value="#F0F4FA" />
            <Setter Property="Padding" Value="8,6" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#2E6695" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#253042" />
            <Setter Property="Foreground" Value="#EAF0FF" />
            <Setter Property="BorderBrush" Value="#3A4C65" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Row="0">
            <StackPanel>
                <TextBlock FontSize="30" FontWeight="SemiBold" Text="Tracker Settings" Margin="0,0,0,10" />

                <CheckBox x:Name="ScreenshotEnabledCheckBox" Content="Enable periodic screenshots" />
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="Screenshot interval (minutes):" Width="320" FontSize="16" />
                    <TextBox x:Name="ScreenshotIntervalTextBox" Width="140" Margin="8,0,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="Idle threshold (minutes):" Width="320" FontSize="16" />
                    <TextBox x:Name="IdleThresholdTextBox" Width="140" Margin="8,0,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="Activity tracking interval (seconds):" Width="320" FontSize="16" />
                    <ComboBox x:Name="ActivityIntervalComboBox" Width="160" Margin="8,0,0,0">
                        <ComboBoxItem Content="1" />
                        <ComboBoxItem Content="2" />
                        <ComboBoxItem Content="5" />
                        <ComboBoxItem Content="10" />
                        <ComboBoxItem Content="30" />
                        <ComboBoxItem Content="60" />
                    </ComboBox>
                </StackPanel>

                <Separator Margin="0,14,0,10" />

                <TextBlock Text="Due Alerts" FontSize="18" FontWeight="SemiBold" />
                <CheckBox x:Name="DueSoundEnabledCheckBox" Content="Enable due alert sound" />
                <CheckBox x:Name="DueTrayBalloonEnabledCheckBox" Content="Enable due alert tray balloon" />
                <CheckBox x:Name="Reminder30CheckBox" Content="Enable 30-minute reminder" />
                <CheckBox x:Name="Reminder15CheckBox" Content="Enable 15-minute reminder" />
                <CheckBox x:Name="Reminder5CheckBox" Content="Enable 5-minute reminder" />
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="Due-check interval (seconds):" Width="320" FontSize="16" />
                    <ComboBox x:Name="DueCheckIntervalComboBox" Width="160" Margin="8,0,0,0">
                        <ComboBoxItem Content="10" />
                        <ComboBoxItem Content="30" />
                        <ComboBoxItem Content="60" />
                    </ComboBox>
                </StackPanel>

                <Separator Margin="0,14,0,10" />

                <TextBlock Text="Goals" FontSize="18" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="Daily active goal (hours):" Width="320" FontSize="16" />
                    <TextBox x:Name="DailyGoalHoursTextBox" Width="140" Margin="8,0,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="Daily task goal (count):" Width="320" FontSize="16" />
                    <TextBox x:Name="DailyTaskGoalTextBox" Width="140" Margin="8,0,0,0" />
                </StackPanel>

                <Separator Margin="0,14,0,10" />

                <TextBlock Text="Category Rules" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="One per line. Example: devenv=Coding, chrome=Browsing" Foreground="#9FB3CF" Margin="0,4,0,6" />
                <TextBox x:Name="CategoryRulesTextBox" Height="120" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />

                <Separator Margin="0,14,0,10" />

                <TextBlock Text="Retention Cleanup" FontSize="18" FontWeight="SemiBold" />
                <CheckBox x:Name="RetentionEnabledCheckBox" Content="Enable auto cleanup of old files" />
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="Keep activity JSON days:" Width="320" FontSize="16" />
                    <TextBox x:Name="RetentionActivityTextBox" Width="140" Margin="8,0,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="Keep screenshots days:" Width="320" FontSize="16" />
                    <TextBox x:Name="RetentionScreenshotsTextBox" Width="140" Margin="8,0,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="Keep reports days:" Width="320" FontSize="16" />
                    <TextBox x:Name="RetentionReportsTextBox" Width="140" Margin="8,0,0,0" />
                </StackPanel>

                <Separator Margin="0,14,0,10" />

                <TextBlock Text="Security" FontSize="18" FontWeight="SemiBold" />
                <CheckBox x:Name="PinEnabledCheckBox" Content="Enable PIN lock for dashboard/report access" />
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="Set PIN (leave blank to keep current):" Width="320" FontSize="16" />
                    <PasswordBox x:Name="PinPasswordBox" Width="200" Margin="8,0,0,0" />
                </StackPanel>

                <Separator Margin="0,14,0,10" />

                <TextBlock Text="Backup Encryption" FontSize="18" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="Backup password:" Width="320" FontSize="16" />
                    <PasswordBox x:Name="BackupPasswordBox" Width="200" Margin="8,0,0,0" />
                </StackPanel>

                <Separator Margin="0,14,0,10" />

                <TextBlock Text="Email Report (SMTP)" FontSize="18" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="From:" Width="320" FontSize="16" />
                    <TextBox x:Name="MailFromTextBox" Width="320" Margin="8,0,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="To:" Width="320" FontSize="16" />
                    <TextBox x:Name="MailToTextBox" Width="320" Margin="8,0,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="Mail password/app password:" Width="320" FontSize="16" />
                    <PasswordBox x:Name="MailPasswordBox" Width="320" Margin="8,0,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="SMTP Host:" Width="320" FontSize="16" />
                    <TextBox x:Name="SmtpHostTextBox" Width="320" Margin="8,0,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="SMTP Port:" Width="320" FontSize="16" />
                    <TextBox x:Name="SmtpPortTextBox" Width="120" Margin="8,0,0,0" />
                    <CheckBox x:Name="SmtpSslCheckBox" Content="Use SSL" Margin="12,6,0,0" />
                </StackPanel>

                <Separator Margin="0,14,0,10" />

                <TextBlock Text="Offline Update" FontSize="18" FontWeight="SemiBold" />
                <CheckBox x:Name="OfflineUpdateCheckBox" Content="Enable offline update check" />
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="Manifest folder/file path:" Width="320" FontSize="16" />
                    <TextBox x:Name="OfflineUpdatePathTextBox" Width="320" Margin="8,0,0,0" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Width="100" Margin="0,0,8,0" Content="Save" Click="Save_Click" />
            <Button Width="100" Content="Cancel" Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>
