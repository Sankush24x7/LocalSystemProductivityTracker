<Window x:Class="ProductivityTracker.App.DueAlertWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Due Alert"
        Height="260"
        Width="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1A0F12"
        Foreground="#FFECEE"
        Topmost="True">
    <Border Margin="16" Padding="14" BorderBrush="#FF3B4D" BorderThickness="2" CornerRadius="10" Background="#2A1218">
        <StackPanel>
            <TextBlock Text="Task Due / Overdue" FontSize="22" FontWeight="Bold" Foreground="#FF5060" />
            <TextBlock x:Name="TaskTitleText" Margin="0,10,0,0" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" Foreground="#FFDDE2" />
            <TextBlock x:Name="TaskDetailText" Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#FFC7CF" />
            <TextBlock x:Name="DueText" Margin="0,8,0,0" FontWeight="SemiBold" Foreground="#FF8B99" />
            <Button Content="Acknowledge" Width="130" Height="34" Margin="0,14,0,0" HorizontalAlignment="Right" Click="Acknowledge_Click" Background="#FF3B4D" Foreground="White" BorderBrush="#FF6C79" />
        </StackPanel>
    </Border>
</Window>
