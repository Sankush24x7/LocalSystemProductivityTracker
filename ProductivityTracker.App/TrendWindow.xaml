<Window x:Class="ProductivityTracker.App.TrendWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Productivity Trends"
        Height="560"
        Width="880"
        Background="#0F1622"
        Foreground="#E8F0FF"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#101B2B" />
            <Setter Property="Foreground" Value="#EAF0FF" />
            <Setter Property="BorderBrush" Value="#324A6D" />
            <Setter Property="RowBackground" Value="#0F1826" />
            <Setter Property="AlternatingRowBackground" Value="#122036" />
            <Setter Property="HorizontalGridLinesBrush" Value="#25364F" />
            <Setter Property="VerticalGridLinesBrush" Value="#25364F" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A2940" />
            <Setter Property="Foreground" Value="#EAF0FF" />
            <Setter Property="BorderBrush" Value="#2B3A4E" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="#EAF0FF" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2E6695" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="#EAF0FF" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#25364F" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="8,4" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2E6695" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ProgressBar">
            <Setter Property="Foreground" Value="#45C4B0" />
            <Setter Property="Background" Value="#1A2940" />
            <Setter Property="BorderBrush" Value="#324A6D" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#253042" />
            <Setter Property="Foreground" Value="#EAF0FF" />
            <Setter Property="BorderBrush" Value="#3A4C65" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Weekly / Monthly Trend Dashboard" FontSize="26" FontWeight="SemiBold" />

        <Grid Grid.Row="1" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="#16243A" CornerRadius="10" Margin="4" Padding="10">
                <StackPanel>
                    <TextBlock Text="7-Day Active" Foreground="#9FB3CF" />
                    <TextBlock x:Name="WeekActiveText" FontSize="20" FontWeight="Bold" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#16243A" CornerRadius="10" Margin="4" Padding="10">
                <StackPanel>
                    <TextBlock Text="30-Day Active" Foreground="#9FB3CF" />
                    <TextBlock x:Name="MonthActiveText" FontSize="20" FontWeight="Bold" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#16243A" CornerRadius="10" Margin="4" Padding="10">
                <StackPanel>
                    <TextBlock Text="Today Goal (Hours)" Foreground="#9FB3CF" />
                    <TextBlock x:Name="GoalHoursText" FontSize="20" FontWeight="Bold" />
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Background="#16243A" CornerRadius="10" Margin="4" Padding="10">
                <StackPanel>
                    <TextBlock Text="Today Goal (Tasks)" Foreground="#9FB3CF" />
                    <TextBlock x:Name="GoalTasksText" FontSize="20" FontWeight="Bold" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="TrendGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None"
                      Margin="0,0,8,0"
                      BorderBrush="#324A6D"
                      Foreground="#EAF0FF">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="*" />
                    <DataGridTextColumn Header="Active" Binding="{Binding Active}" Width="*" />
                    <DataGridTextColumn Header="Idle" Binding="{Binding Idle}" Width="*" />
                    <DataGridTextColumn Header="Score" Binding="{Binding Score}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                <TextBlock Text="Goal Progress" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />

                <DockPanel>
                    <TextBlock Text="Active Hours Goal" />
                    <TextBlock x:Name="HoursGoalPctText" DockPanel.Dock="Right" Foreground="#AFC5E6" />
                </DockPanel>
                <ProgressBar x:Name="HoursGoalProgress" Height="20" Maximum="100" Margin="0,4,0,12" />

                <DockPanel>
                    <TextBlock Text="Tasks Goal" />
                    <TextBlock x:Name="TasksGoalPctText" DockPanel.Dock="Right" Foreground="#AFC5E6" />
                </DockPanel>
                <ProgressBar x:Name="TasksGoalProgress" Height="20" Maximum="100" Margin="0,4,0,12" />

                <TextBlock x:Name="GoalHintText" TextWrapping="Wrap" Foreground="#AFC5E6" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Width="110" Height="32" Content="Refresh" Margin="0,0,8,0" Click="Refresh_Click" />
            <Button Width="110" Height="32" Content="Close" Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>

